--> [compiler]
local compiler_res = safehttpget('https://unemployed.altcontrol.club/paths.json')
local compiler_json = httpservice:JSONDecode(compiler_res)

local package = {}
local api

if ok and ok.Developer then
    api = loadfile('altcontrol/api.lua')()
else
    local res = safehttpget('https://unemployed.altcontrol.club/api.lua');
    local decrypted = enc.decrypt(detectandreverse(res));
    api = safeload(decrypted)();
end

for i, v in api do
    package[i] = v
end

for _, v in compiler_json do
    if not v then
        continue
    end
    if ok and ok.Developer then continue end

    local res = safehttpget(`https://unemployed.altcontrol.club/modules/`..v)
    if not res then
        logger.error(`Failed to load a module. ({v:gsub('.lua', '')})`);
        continue
    end

    local decrypted = enc.decrypt(detectandreverse(res));
    if decrypted and decrypted ~= '' then
        local chunk, err = safeload(decrypted)
        if chunk then
            task.spawn(chunk, package)
        else
            warn(`[altcontrol] Failure loading {v}: {err}`)
        end
    end
end

local customfiles = listfiles('altcontrol/custom');
if customfiles and not ok.IgnoreCustomFiles then
    for i, v in customfiles do
        v = v:gsub('\\', '/')
        local file = isfile(v) and readfile(v) or nil;
        if file and file ~= '' then
            local chunk, err = safeload(file)
            if chunk then
                task.spawn(chunk, package)
            else
                warn(`[altcontrol] Failure loading {v}: {err}`)
            end
        end
    end
end
